<?xml version='1.0'?>
<!--
***************************************************************
* This XSL specifies character encoding for HTML              *
***************************************************************-->

<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
<xsl:strip-space elements="*"/>
<xsl:output media-type="text/html" encoding="ISO-8859-1"/>
</xsl:stylesheet>
